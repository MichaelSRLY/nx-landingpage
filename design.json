{
  "name": "Nexora Global Design Logic",
  "version": "1.1.0",
  "description": "Premium industrial aesthetic for Nexora, featuring high-precision scaling and warm paper tones.",
  "tokens": {
    "colors": {
      "light": {
        "background": "hsl(40, 25%, 95%)",
        "surface": "hsl(40, 25%, 95%)",
        "foreground": "hsl(30, 15%, 15%)",
        "muted-foreground": "hsl(30, 10%, 40%)",
        "border": "hsl(35, 15%, 85%)",
        "accent": "hsl(35, 20%, 88%)"
      },
      "dark": {
        "background": "hsl(30, 5%, 10%)",
        "surface": "hsl(30, 5%, 10%)",
        "foreground": "hsl(40, 20%, 92%)",
        "muted-foreground": "hsl(40, 15%, 60%)",
        "border": "hsl(30, 5%, 18%)",
        "accent": "hsl(35, 20%, 25%)"
      }
    },
    "typography": {
      "families": {
        "sans": "Inter, system-ui, sans-serif",
        "mono": "Geist Mono, ui-monospace, monospace"
      },
      "scale": {
        "hero": "clamp(32px, 10vw, 64px)",
        "h2": "clamp(28px, 6vw, 42px)",
        "h3": "clamp(20px, 4vw, 32px)",
        "body": "16px",
        "tiny": "10px"
      },
      "weights": {
        "thin": "100",
        "light": "300",
        "regular": "400",
        "medium": "500",
        "semibold": "600"
      }
    },
    "spacing": {
      "desktop": {
        "section": "160px 40px",
        "maxContent": "1200px"
      },
      "mobile": {
        "section": "60px 20px"
      }
    },
    "effects": {
      "shadows": {
        "premium": "0 2px 4px rgba(0,0,0,0.02), 0 32px 64px rgba(0,0,0,0.02)",
        "glass": "0 4px 32px 0 rgba(0,0,0,0.02)"
      },
      "patterns": {
        "grain": "radial-gradient(at 50% 20%, rgba(160, 120, 70, 0.05) 0%, transparent 50%)",
        "noise": "data:image/svg+xml,...fractalNoise..."
      }
    }
  },
  "components": {
    "appCard": {
      "borderRadius": "24px",
      "borderWidth": "1px",
      "padding": "40px",
      "hoverEffect": "translateY(-12px) scale(1.02)"
    },
    "bento": {
      "gap": "20px",
      "rowHeight": "200px"
    },
    "processVisual": {
      "desktopAspect": "1/1",
      "mobileAspect": "4/3",
      "borderRadius": "40px"
    }
  }
}