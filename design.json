{
  "name": "Nexora Warm Paper Design System",
  "version": "1.0.0",
  "description": "A papery, warm aesthetic anchored in HSL 30-40, inspired by the works of M.C. Escher.",
  "tokens": {
    "colors": {
      "light": {
        "background": "hsl(40, 30%, 97%)",
        "surface": "hsl(40, 25%, 95%)",
        "text": {
          "primary": "hsl(30, 15%, 15%)",
          "secondary": "hsl(30, 10%, 40%)",
          "muted": "hsl(35, 10%, 60%)"
        },
        "border": "hsl(35, 15%, 85%)",
        "accent": "hsl(35, 20%, 88%)",
        "secondary": "hsl(35, 20%, 90%)"
      },
      "dark": {
        "background": "hsl(30, 5%, 10.5%)",
        "surface": "hsl(30, 5%, 12%)",
        "text": {
          "primary": "hsl(40, 20%, 92%)",
          "secondary": "hsl(40, 15%, 70%)",
          "muted": "hsl(30, 10%, 50%)"
        },
        "border": "hsl(30, 5%, 20%)",
        "accent": "hsl(35, 20%, 30%)",
        "secondary": "hsl(35, 15%, 25%)"
      }
    },
    "typography": {
      "families": {
        "sans": "Geist Sans, system-ui, sans-serif",
        "mono": "Geist Mono, monospace"
      },
      "scale": {
        "desktop": {
          "h1": "4rem",
          "h2": "2rem",
          "h3": "1.5rem",
          "body": "1rem",
          "small": "0.875rem",
          "tiny": "0.75rem"
        },
        "mobile": {
          "h1": "2.25rem",
          "h2": "1.5rem",
          "h3": "1.25rem",
          "body": "0.875rem",
          "small": "0.75rem",
          "tiny": "0.625rem"
        }
      },
      "weights": {
        "thin": "100",
        "extralight": "200",
        "light": "300",
        "regular": "400",
        "semibold": "600",
        "bold": "700"
      }
    },
    "spacing": {
      "xs": "4px",
      "sm": "8px",
      "md": "16px",
      "lg": "32px",
      "xl": "64px",
      "xxl": "128px"
    },
    "effects": {
      "shadows": {
        "sm": "0 1px 2px rgba(0,0,0,0.05)",
        "md": "0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06)",
        "paper": "0 20px 25px -5px rgba(0,0,0,0.05), 0 10px 10px -5px rgba(0,0,0,0.02)"
      },
      "patterns": {
        "grain": "radial-gradient(at 50% 20%, rgba(160, 120, 70, 0.06) 0%, transparent 50%)",
        "noise": "url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.7' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E\")"
      }
    }
  },
  "components": {
    "card": {
      "borderRadius": "8px",
      "borderWidth": "1px",
      "padding": "24px"
    },
    "timeline": {
      "markerSize": "36px",
      "connectorWidth": "1px",
      "gap": "28px"
    }
  }
}
